# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.venv311
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# partykit
.partykit/

# runtime uploads / generated catalog
public/uploads/
data/user-songs.json

# runtime job state (fire-and-forget pipeline jobs)
data/jobs/

# python cache
scripts/__pycache__/
**/__pycache__/
*.pyc

# pipeline debug outputs (archivos temporales de pruebas)
pipeline_*.json
pipeline_*.log
